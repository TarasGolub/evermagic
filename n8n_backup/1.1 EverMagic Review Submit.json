    {
      "parameters": {
        "jsCode": "const submitData = $('Handle Submit').first().json;\nconst orderId = submitData.order_id;\nconst feedback = submitData.feedback;\nconst newVersion = submitData.new_version;\n\nconst systemPrompt = $('Fetch Prompt').first().json.data;\nconst currentScript = $('Fetch Current Script').first().json.content;\nconst order = $('Fetch Order').first().json;\nconst child = order.child || {};\n\nconst userPrompt = `You previously generated this story:\\n\\n\\`\\`\\`json\\n${JSON.stringify(currentScript, null, 2)}\\n\\`\\`\\`\\n\\nThe reviewer has provided the following feedback. Please regenerate the script incorporating these changes:\\n\\n**Reviewer Feedback:**\\n${feedback}\\n\\n**Original order details (for reference):**\\n- Name: ${child.name}\\n- Age: ${child.age}\\n- Gender: ${child.gender}\\n- Hobby: ${child.hobby}\\n- Hobby details: ${child.hobby_detail || 'not provided'}\\n- Signature look: ${child.signature_look || 'not provided'}\\n- Theme: ${order.theme}\\n- Hero trait: ${child.hero_trait}\\n- Parent message: ${order.parent_message || 'No message provided.'}\\n\\nPlease output the COMPLETE revised script in the exact same JSON format.`;\n\nreturn [{\n  json: {\n    system_prompt: systemPrompt,\n    user_prompt: userPrompt,\n    order_id: orderId,\n    version: newVersion,\n    feedback: feedback,\n    order: order\n  }\n}];"
      },

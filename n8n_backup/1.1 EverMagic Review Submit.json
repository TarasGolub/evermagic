    {
      "parameters": {
        "jsCode": "const query = $('Webhook').first().json.query || {};\n\nconst orderId = query.order_id;\nconst version = parseInt(query.version || '1', 10);\nconst action = (query.action || '').toLowerCase();\n\nif (!orderId) {\n  return [{\n    json: {\n      action: 'error',\n      html: '<html><body style=\"font-family:sans-serif;display:flex;align-items:center;justify-content:center;min-height:100vh;margin:0;\"><div style=\"text-align:center;\"><h1>❌ Error</h1><p>Missing order_id parameter.</p></div></body></html>'\n    }\n  }];\n}\n\nif (!['approve', 'retry', 'edit'].includes(action)) {\n  return [{\n    json: {\n      action: 'error',\n      html: '<html><body style=\"font-family:sans-serif;display:flex;align-items:center;justify-content:center;min-height:100vh;margin:0;\"><div style=\"text-align:center;\"><h1>❌ Error</h1><p>Invalid action.</p></div></body></html>'\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    action,\n    order_id: orderId,\n    version\n  }\n}];"
      },

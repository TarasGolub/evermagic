        -1408,
        208
      ],
      "webhookId": "b0478527-1df8-4d4c-b58d-35b210d79232"
    },
    {
      "parameters": {
        "jsCode": "const body = $('Webhook').first().json.body || $('Webhook').first().json;\n\nconst orderId = body.order_id;\nconst currentVersion = parseInt(body.version || '1', 10);\nconst action = (body.action || '').toLowerCase();\nconst newVersion = currentVersion + 1;\n\nif (action === 'retry_submit') {\n  const feedback = body.feedback || '';\n  return [{\n    json: {\n      action: 'retry',\n      order_id: orderId,\n      current_version: currentVersion,\n      new_version: newVersion,\n      feedback: feedback,\n      html: `<!DOCTYPE html><html><head><meta charset=\"utf-8\"><title>🔄 Regenerating...</title><style>body{font-family:'Segoe UI',sans-serif;display:flex;align-items:center;justify-content:center;min-height:100vh;background:#f8f9fa;margin:0;}.card{text-align:center;background:#fff;padding:48px;border-radius:16px;box-shadow:0 2px 8px rgba(0,0,0,0.06);}h1{font-size:24px;color:#111;margin-bottom:8px;}p{color:#6b7280;font-size:14px;}</style></head><body><div class=\"card\"><div style=\"font-size:48px;margin-bottom:16px;\">🔄</div><h1>Regenerating Script...</h1><p>Order: <strong>${orderId}</strong> · Creating version v${newVersion}</p><p style=\"margin-top:16px;\">You'll receive a new review email shortly.</p></div></body></html>`\n    }\n  }];\n}\n\nif (action === 'edit_submit') {\n  let scriptContent;\n  try {\n    scriptContent = typeof body.script === 'string' ? JSON.parse(body.script) : body.script;\n  } catch (e) {\n    return [{\n      json: {\n        action: 'error',\n        html: `<html><body style=\"font-family:sans-serif;padding:40px;\"><h1>❌ Invalid JSON</h1><p>${e.message}</p><p><a href=\"javascript:history.back()\">Go back</a></p></body></html>`\n      }\n    }];\n  }\n  return [{\n    json: {\n      action: 'edit_save',\n      order_id: orderId,\n      current_version: currentVersion,\n      new_version: newVersion,\n      script: scriptContent,\n      script_raw: JSON.stringify(scriptContent),\n      html: `<!DOCTYPE html><html><head><meta charset=\"utf-8\"><title>✅ Saved</title><style>body{font-family:'Segoe UI',sans-serif;display:flex;align-items:center;justify-content:center;min-height:100vh;background:#f0fdf4;margin:0;}.card{text-align:center;background:#fff;padding:48px;border-radius:16px;box-shadow:0 2px 8px rgba(0,0,0,0.06);}h1{font-size:24px;color:#16a34a;margin-bottom:8px;}p{color:#6b7280;font-size:14px;}</style></head><body><div class=\"card\"><div style=\"font-size:48px;margin-bottom:16px;\">✅</div><h1>Script Saved & Approved!</h1><p>Order: <strong>${orderId}</strong> · Version v${newVersion}</p><p style=\"margin-top:16px;\">The order is now ready for the next phase.</p></div></body></html>`\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    action: 'error',\n    html: '<html><body><h1>❌ Unknown action</h1></body></html>'\n  }\n}];"
      },

    {
      "parameters": {
        "jsCode": "const order = JSON.parse($('Fetch Order Payload').first().json.payload_json);\nconst child = order.child;\nconst scriptRow = $('Fetch Script').first().json;\nconst scriptContent = typeof scriptRow.content === 'string' ? JSON.parse(scriptRow.content) : scriptRow.content;\nconst expandedContent = scriptRow.expanded_content\n  ? (typeof scriptRow.expanded_content === 'string' ? JSON.parse(scriptRow.expanded_content) : scriptRow.expanded_content)\n  : null;\n\nconst imageRows = $('Fetch Images').all();\nconst images = {};\nfor (const row of imageRows) { images[row.json.image_type] = row.json.file_url; }\n\nconst env = $('Envs').first().json.env;\nconst qrCodeUrl = env.qr_code_url || '';\n\nfunction sceneText(n) {\n  if (expandedContent && expandedContent.scenes) {\n    const ex = expandedContent.scenes.find(s => s.scene_number === n);\n    if (ex && ex.expanded_narrative) return ex.expanded_narrative;\n  }\n  const s = scriptContent.scenes.find(s => s.scene_number === n);\n  return s ? s.narration : '';\n}\nfunction sceneTitle(n) {\n  const s = scriptContent.scenes.find(s => s.scene_number === n);\n  return s ? s.scene_title : '';\n}\n\nconst heroTraitTitle = child.hero_trait\n  ? child.hero_trait.charAt(0).toUpperCase() + child.hero_trait.slice(1)\n  : 'Courage';\n\nconst citation = `In recognition of extraordinary ${child.hero_trait || 'courage'}, curiosity of mind, and strength of heart — demonstrated throughout the Space Hero Mission, where ${child.name} used knowledge, courage, and the remarkable power of ${child.hobby ? child.hobby.toLowerCase() : 'imagination'} to save an entire constellation and bring light back to the universe.`;\n\nconst today = new Date();\nconst awardDate = today.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });\n\nconst vars = {\n  'story.title': scriptContent.title || '',\n  'story.tagline': scriptContent.tagline || '',\n  'closing_message': scriptContent.closing_message || '',\n  'parent_message': order.parent_message || '',\n  'child.name': child.name,\n  'child.age': String(child.age),\n  'child.hero_trait': child.hero_trait || '',\n  'child.hobby': child.hobby || '',\n  'order.order_id': order.order_id,\n  'qr_code_url': qrCodeUrl,\n  'cover.image_url': images['cover'] || '',\n  'scene_1.image_url': images['scene_1'] || '',\n  'scene_2.image_url': images['scene_2'] || '',\n  'scene_3.image_url': images['scene_3'] || '',\n  'scene_4.image_url': images['scene_4'] || '',\n  'scene_5.image_url': images['scene_5'] || '',\n  'coloring.image_url': images['coloring'] || '',\n  'coloring_1.image_url': images['coloring_1'] || '',\n  'coloring_2.image_url': images['coloring_2'] || '',\n  'coloring_3.image_url': images['coloring_3'] || '',\n  'coloring_4.image_url': images['coloring_4'] || '',\n  'coloring_5.image_url': images['coloring_5'] || '',\n  'scene_1.title': sceneTitle(1), 'scene_2.title': sceneTitle(2),\n  'scene_3.title': sceneTitle(3), 'scene_4.title': sceneTitle(4), 'scene_5.title': sceneTitle(5),\n  'scene_1.narration': sceneText(1), 'scene_2.narration': sceneText(2),\n  'scene_3.narration': sceneText(3), 'scene_4.narration': sceneText(4), 'scene_5.narration': sceneText(5),\n  'cert.hero_trait_title': heroTraitTitle,\n  'cert.citation': citation,\n  'cert.date': awardDate\n};\n\nfunction injectVars(html, variables) {\n  let result = html;\n  for (const [key, value] of Object.entries(variables)) {\n    const regex = new RegExp('\\\\{\\\\{' + key.replace('.', '\\\\.') + '\\\\}\\\\}', 'g');\n    result = result.replace(regex, value);\n  }\n  return result;\n}\n\nconst apiKey = env.pdfshift_api_key || '';\nconst authHeader = 'Basic ' + Buffer.from('api:' + apiKey).toString('base64');\n\nconst PDF_TYPES = [\n  { type: 'storybook',     template_node: 'Fetch Storybook Template',     options: { width: '7in', height: '7in', landscape: false } },\n  { type: 'coloring_book', template_node: 'Fetch Coloring Book Template', options: { format: 'Letter',  landscape: false } },\n  { type: 'certificate',   template_node: 'Fetch Certificate Template',   options: { format: 'Letter',  landscape: true  } }\n];\n\nconst results = [];\nfor (const pdfType of PDF_TYPES) {\n  const rawHtml = $(pdfType.template_node).first().json.data;\n  const html = injectVars(rawHtml, vars);\n  const body = { source: html, landscape: pdfType.options.landscape || false };\n  if (pdfType.options.format) {\n    body.format = pdfType.options.format;\n  } else {\n    body.width = pdfType.options.width;\n    body.height = pdfType.options.height;\n  }\n  results.push({ json: {\n    order_id:       order.order_id,\n    pdf_type:       pdfType.type,\n    pdfshift_body:  body,\n    pdfshift_auth:  authHeader,\n    file_path:      'pdfs/' + order.order_id + '/' + pdfType.type + '.pdf',\n    supabase_url:   env.supabase_url || '',\n    supabase_key:   env.supabase_service_key || ''\n  }});\n}\nreturn results;\n"
      },

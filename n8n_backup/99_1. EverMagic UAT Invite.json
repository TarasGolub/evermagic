        "jsCode": "const raw = {};\nfor (const item of $input.all()) {\n  raw[item.json.key] = item.json.value;\n}\n\nconst env = {\n  mode:          raw.mode,\n  is_live:       raw.mode === 'live',\n  tally_form_id: raw.tally_form_id,\n};\n\nreturn [{ json: { env } }];\n"

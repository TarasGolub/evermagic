    {
      "parameters": {
        "url": "=https://raw.githubusercontent.com/TarasGolub/evermagic/{{ $('Envs').first().json.env.is_live ? 'main' : 'develop' }}/emails/uat-invite.html",
        "options": {}
      },
      "id": "44ee1cbf-fc17-4ca7-a72d-76f8a5990d92",
      "name": "Fetch Invite Email Template",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1392,
        -96
      ]
    },
    {
      "parameters": {
        "jsCode": "const participant = $('Loop Over Participants').first().json;\nconst tokenRow    = $('Fetch Unused Token').first().json;\nconst template    = $('Fetch Invite Email Template').first().json.data;\nconst env         = $('Envs').first().json.env;\n\nif (!tokenRow || !tokenRow.token) {\n  throw new Error('No unused UAT tokens available — run the seed SQL to generate more.');\n}\n\nconst tallyFormId = env.tally_form_id;\nif (!tallyFormId) throw new Error('Missing env: tally_form_id — add it to the envs table in Supabase.');\n\n// Build personalised Tally URL\n// source=UAT  → copied to orders.source, triggers feedback email after delivery\n// orderNo     → friend's name, used for tracking in Supabase\nconst tallyUrl =\n  `https://tally.so/r/${tallyFormId}` +\n  `?source=UAT` +\n  `&orderNo=${encodeURIComponent(participant.name)}` +\n  `&token=${tokenRow.token}`;\n\nconst branch  = env.is_live ? 'main' : 'develop';\nconst logoUrl = `https://raw.githubusercontent.com/TarasGolub/evermagic/${branch}/templates/icons/logo_email.png`;\n\nconst html = template\n  .replace(/\\{\\{logo_url\\}\\}/g,    logoUrl)\n  .replace(/\\{\\{friend_name\\}\\}/g, participant.name)\n  .replace(/\\{\\{tally_url\\}\\}/g,   tallyUrl);\n\nreturn [{\n  json: {\n    participant_id: participant.id,\n    participant_name: participant.name,\n    token: tokenRow.token,\n    tally_url: tallyUrl,\n    to:      participant.contact,\n    subject: `${participant.name}, early tester invite — your honest feedback would mean a lot. Taras`,\n    html,\n  }\n}];\n"
      },
      "id": "2e2186b1-8281-4c23-8eb9-aa2c2f3b3b70",
      "name": "Build Invite Email",
      "type": "n8n-nodes-base.code",
